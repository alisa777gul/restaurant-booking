generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Reservation {
  id Int @id @default(autoincrement())

  name String
  phone String
  email String

  date String
  time String

  guests String

  serviceId Int

  service Service @relation(fields: [serviceId], references: [id])

  status String @default("PENDING")

  createdAt DateTime @default(now())

  @@unique([date, time])
}

model AvailableTime {
  id Int @id @default(autoincrement())

  time String @unique

  active Boolean @default(true)
}

model BlockedDate {
  id Int @id @default(autoincrement())

  date String @unique

  reason String?
}

model TimeSlot {
  id Int @id @default(autoincrement())

  date String

  time String

  available Boolean @default(true)

  createdAt DateTime @default(now())
}

model WorkingHour {
  id Int @id @default(autoincrement())

  day String @unique

  open String

  close String

  closed Boolean @default(false)

  slotDuration Int @default(30)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model DateOverride {
  id Int @id @default(autoincrement())

  // The specific calendar date in "YYYY-MM-DD" format.
  date String @unique

  // When true, the restaurant is fully closed on this date and no
  // time slots are generated, regardless of the weekly working hours.
  closed Boolean @default(false)

  // Optional custom opening/closing time for this date. When provided
  // (and closed = false) these override the weekly WorkingHour for the
  // weekday, which enables "special openings".
  open String?

  close String?

  // Optional custom slot duration (minutes) for this date.
  slotDuration Int?

  // Optional note shown in the admin panel (e.g. "Public holiday").
  reason String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model RestaurantSettings {
  id Int @id @default(autoincrement())

  name String @default("Restaurant")

  phone String?

  email String?

  address String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model Service {
  id Int @id @default(autoincrement())

  name String

  description String?

  duration Int

  price Int?

  active Boolean @default(true)

  reservations Reservation[]

  createdAt DateTime @default(now())
}
